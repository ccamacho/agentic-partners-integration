FROM python:3.11-slim

WORKDIR /app

# Install dependencies
RUN pip install --no-cache-dir \
    fastapi \
    uvicorn[standard] \
    chromadb \
    google-genai \
    structlog

# Copy RAG service
COPY rag-service/rag_service.py /app/
COPY rag-service/ingest_knowledge.py /app/

# Copy sample data
COPY data /app/data

# Expose port
EXPOSE 8080

# Run the RAG service
CMD ["python", "rag_service.py"]
